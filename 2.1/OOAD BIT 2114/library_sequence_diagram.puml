@startuml LibrarySystem_SequenceDiagram

title Sequence Diagram: Student Borrowing a Book

actor "Student" as S
participant "Librarian" as L
participant "System" as Sys
database "Database" as DB

S -> L: 1: requestBook(bookId)
activate L

L -> Sys: 2: searchBook(bookId)
activate Sys
Sys -> DB: 3: findBook(bookId)
activate DB
DB --> Sys: 4: bookDetails
deactivate DB
Sys --> L: 5: bookFound
deactivate Sys

L -> Sys: 6: checkStudent(studentId)
activate Sys
Sys -> DB: 7: findStudent(studentId)
activate DB
DB --> Sys: 8: studentDetails
deactivate DB
Sys --> L: 9: studentValid
deactivate Sys

L -> Sys: 10: issueBook(studentId, bookId)
activate Sys
Sys -> DB: 11: updateBookStatus(bookId, "borrowed")
activate DB
DB --> Sys: 12: statusUpdated
deactivate DB
Sys -> DB: 13: addBorrowRecord(studentId, bookId, date)
activate DB
DB --> Sys: 14: recordAdded
deactivate DB
Sys --> L: 15: bookIssued
deactivate Sys

L --> S: 16: handOverBook()

@enduml
