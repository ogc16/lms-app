@startuml AmbulanceBooking_ClassDiagram

skinparam classAttributeIconSize 0

title "Fully Adorned Conceptual Class Diagram\nAmbulance Booking System"

abstract class AmbulanceBooking {
  - bookingId: int
  - pickUpAddress: String
  - dropOffAddress: String
  # form: Form
  + AmbulanceBooking(id: int, pickup: String, dropoff: String)
  + getBookingId(): int
  + getPickUpAddress(): String
  + getDropOffAddress(): String
  + setForm(f: Form): void
  + processBooking(): void
  # handleProcessing(): void
  # validateBooking(): void
  # finalizeBooking(): void
  # handleExtra(): void
  # sendToDispatcher(): void
}

note right of AmbulanceBooking
  **Template Method Pattern**
  processBooking() defines steps:
  1. validateBooking() [common]
  2. handleProcessing() [subclass]
  3. handleExtra() [hook]
  4. finalizeBooking() [common]
  5. sendToDispatcher() [common]
end note

class AS3Booking {
  - appointmentTime: DateTime
  + AS3Booking(id: int, pickup: String, dropoff: String, apptTime: DateTime)
  + getAppointmentTime(): DateTime
  # handleProcessing(): void
}

class AS2Booking {
  - pickupTime: DateTime
  + AS2Booking(id: int, pickup: String, dropoff: String, pickupTime: DateTime)
  + getPickupTime(): DateTime
  # handleProcessing(): void
}

class AS1Booking {
  - emergencyType: String
  - priorityLevel: int
  + AS1Booking(id: int, pickup: String, dropoff: String, pickupTime: DateTime, emergencyType: String, priorityLevel: int)
  + getEmergencyType(): String
  + getPriorityLevel(): int
  # handleExtra(): void
}

abstract class Form {
  - formNumber: String
  + Form(number: String)
  + getFormNumber(): String
  + fillForm(): void
}

class AS3Form {
  - appointmentSection: String
  + AS3Form(number: String)
  + fillForm(): void
}

class AS2Form {
  - patientDetailsSection: String
  + AS2Form(number: String)
  + fillForm(): void
}

class AS1Form {
  - emergencyDetailsSection: String
  - triageNotes: String
  + AS1Form(number: String)
  + fillForm(): void
}

class Dispatcher {
  - dispatcherId: int
  - name: String
  + Dispatcher(id: int, name: String)
  + dispatchBooking(booking: AmbulanceBooking): void
  + assignAmbulance(booking: AmbulanceBooking): void
}

' ===== INHERITANCE =====
AmbulanceBooking <|-- AS3Booking
AmbulanceBooking <|-- AS2Booking
AS2Booking <|-- AS1Booking

Form <|-- AS3Form
Form <|-- AS2Form
AS2Form <|-- AS1Form

' ===== ASSOCIATIONS =====
AmbulanceBooking "1" -- "1" Form : uses >

Dispatcher "1" --> "0..*" AmbulanceBooking : dispatches >

note right of Dispatcher
  All processed bookings
  are sent here
end note
@enduml
